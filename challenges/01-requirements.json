[
  {
    "id": "BENCH-001",
    "title": "Requirement without formal model",
    "category": "requirements",
    "difficulty": "easy",
    "description": "Add a new requirement to requirements.json without a corresponding formal model entry, creating an R->F gap",
    "target_layers": ["r_to_f"],
    "mutation": {
      "type": "json-entry-add",
      "target_file": ".planning/formal/requirements.json",
      "json_path": "$.requirements",
      "value": {
        "id": "BENCH-FAKE-01",
        "text": "Benchmark synthetic requirement with no formal model coverage",
        "category": "Benchmark",
        "tier": "user",
        "phase": "unknown",
        "status": "Complete",
        "provenance": { "source_file": "benchmark", "milestone": "benchmark" },
        "formal_models": [],
        "category_raw": "Benchmark"
      },
      "description": "Add a requirement with empty formal_models array"
    },
    "expected_outcome": {
      "residual_change": "increase",
      "description": "nf:solve should detect R->F gap for BENCH-FAKE-01",
      "layers_affected": ["r_to_f"]
    },
    "scoring": {
      "method": "residual_layer_zero",
      "target_layer": "r_to_f",
      "timeout_seconds": 300
    },
    "tags": ["requirements", "r_to_f", "synthetic"]
  },
